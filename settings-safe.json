{
  "permissions": {
    "allow": [
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(git:*)",
      "Bash(gh:*)",
      "Bash(curl:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(cat:*)",
      "Bash(pwd:*)",
      "Bash(which:*)",
      "Bash(where:*)",
      "Bash(dir:*)",
      "Bash(type:*)",
      "Bash(openssl:*)",
      "Bash(python:*)",
      "Bash(pip:*)",
      "Bash(cargo:*)",
      "Bash(rustup:*)",
      "WebSearch",
      "WebFetch",
      "Bash(tree:*)",
      "Bash(npx create-next-app:*)",
      "Bash(npx create-next-app@latest:*)",
      "Bash(npx shadcn@latest init -d)",
      "Bash(npx shadcn@latest add:*)",
      "Bash(npm uninstall:*)",
      "Bash(npx tsx:*)",
      "Bash(timeout:*)",
      "Bash(ping:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(echo:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git checkout:*)",
      "Bash(git pull:*)",
      "Bash(git merge:*)",
      "Bash(git fetch:*)",
      "Bash(git reset:*)",
      "Bash(git restore:*)",
      "Bash(git clean:*)",
      "Bash(git grep:*)",
      "Bash(git mv:*)",
      "Bash(npm run dev:*)",
      "Bash(npm run start)",
      "Bash(npm run lint)",
      "Bash(npm run build)",
      "Bash(npm run test:*)",
      "Bash(npm ls:*)",
      "Bash(npm view:*)",
      "Bash(npx next build:*)",
      "Bash(npx md-to-pdf:*)",
      "Bash(node -e:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm test:*)",
      "Bash(source:*)",
      "Bash(export:*)",
      "Bash(vercel:*)",
      "Bash(taskkill:*)",
      "Bash(tasklist:*)",
      "Bash(netstat:*)",
      "Bash(findstr:*)",
      "Bash(nslookup:*)",
      "Bash(copy:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(drop table:*)"
    ]
  },
  "hooks": {
    "PreCompact": [
      {
        "matcher": "auto",
        "hooks": [
          {
            "type": "command",
            "command": "echo CONTEXT_SAVE_TRIGGERED"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "$input = $input | ConvertFrom-Json; $used = $input.context_window.used_percentage; $model = $input.model.display_name; if ($used -ne $null) { \"Context: $([math]::Round($used))% | $model\" } else { \"$model\" }"
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "alwaysThinkingEnabled": true
}
